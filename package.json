{
  "name": "prototype-studio",
  "version": "1.0.0",
  "description": "CLI tool for frontend prototyping with LLM assistance — review, annotate, and iterate on HTML prototypes",
  "type": "module",
  "bin": {
    "proto": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:browser": "vitest run --config vitest.pw.config.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "prototype",
    "llm",
    "annotation",
    "html",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "chokidar": "^4.0.0",
    "clipboardy": "^4.0.0",
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "open": "^10.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^3.0.0",
    "playwright": "^1.58.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
